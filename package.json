{
  "name": "idle-farm",
  "version": "0.1.0",
  "description": "作業に寄生する常駐型インフレゲーム（農業テーマ）",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.idlefarm.app",
    "productName": "IdleFarm",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "keywords": [
    "idle",
    "game",
    "farming",
    "electron"
  ],
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2"
  }
}
